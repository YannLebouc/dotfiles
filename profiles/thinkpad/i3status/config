general {
    colors = true
    interval = 1
}

order += "battery all"
order += "volume master"
order += "wireless _first_"
order += "ethernet _first_"
order += "cpu_usage"
order += "memory"
order += "disk /"
order += "tztime local"

battery all {
    format = "BAT %status %percentage %remaining"
    format_down = "BAT missing"
    status_chr = "⚡"
    status_bat = "🔋"
    status_full = "✔"
}

volume master {
    format = "VOL %volume"
    format_muted = "MUTED"
    device = "default"
    mixer = "Master"
}

wireless _first_ {
    format_up = "WIFI %essid"
    format_down = "WIFI down"
}

ethernet _first_ {
    format_up = "NET %ip"
    format_down = "NET down"
}

cpu_usage { format = "CPU %usage" }
memory    { format = "RAM %used/%total" }
disk "/"  { format = "SSD %avail" }

tztime local { format = "%Y-%m-%d %H:%M" }
